<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/overlay_root"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/overlay_bg_running"
    android:minWidth="@dimen/overlay_min_width"
    android:elevation="@dimen/overlay_elevation">

    <FrameLayout
        android:id="@+id/overlay_mini_container"
        android:layout_width="@dimen/overlay_mini_size"
        android:layout_height="@dimen/overlay_mini_size"
        android:background="@drawable/overlay_bg_running_mini"
        android:visibility="gone">

        <ProgressBar
            android:id="@+id/overlay_mini_spinner"
            style="?android:attr/progressBarStyleSmall"
            android:layout_width="@dimen/overlay_mini_spinner_size"
            android:layout_height="@dimen/overlay_mini_spinner_size"
            android:indeterminateTint="@color/overlay_text_primary"
            android:layout_gravity="center" />

    </FrameLayout>

    <LinearLayout
        android:id="@+id/overlay_header"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="@dimen/overlay_header_padding_h"
        android:paddingEnd="@dimen/overlay_header_padding_h"
        android:paddingTop="@dimen/overlay_header_padding_v"
        android:paddingBottom="@dimen/overlay_header_padding_v"
        android:minWidth="@dimen/overlay_min_width"
        android:maxWidth="@dimen/overlay_max_width">

        <ProgressBar
            android:id="@+id/overlay_spinner"
            style="?android:attr/progressBarStyleSmall"
            android:layout_width="@dimen/overlay_spinner_size"
            android:layout_height="@dimen/overlay_spinner_size"
            android:indeterminateTint="@color/overlay_text_primary"
            android:layout_marginEnd="8dp" />

        <TextView
            android:id="@+id/overlay_icon"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="8dp"
            android:textColor="@color/overlay_text_primary"
            android:textSize="@dimen/overlay_text_icon"
            android:textStyle="bold"
            android:visibility="gone"
            android:text="✓" />

        <TextView
            android:id="@+id/overlay_text"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:textColor="@color/overlay_text_primary"
            android:textSize="@dimen/overlay_text_body"
            android:maxLines="2"
            android:ellipsize="end"
            android:text="ClawGUI 运行中" />

    </LinearLayout>

    <ScrollView
        android:id="@+id/overlay_expanded"
        android:layout_width="match_parent"
        android:layout_height="@dimen/overlay_expanded_height"
        android:visibility="gone"
        android:fadeScrollbars="false"
        android:paddingStart="@dimen/overlay_expanded_padding"
        android:paddingEnd="@dimen/overlay_expanded_padding"
        android:paddingBottom="@dimen/overlay_expanded_padding">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="思考"
                android:textColor="@color/overlay_text_label"
                android:textSize="@dimen/overlay_text_label"
                android:textStyle="bold"
                android:paddingBottom="2dp" />

            <TextView
                android:id="@+id/overlay_thinking"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/overlay_text_primary"
                android:textSize="@dimen/overlay_text_body"
                android:textIsSelectable="true"
                android:text="(等待数据)" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="动作"
                android:textColor="@color/overlay_text_label"
                android:textSize="@dimen/overlay_text_label"
                android:textStyle="bold"
                android:paddingTop="8dp"
                android:paddingBottom="2dp" />

            <TextView
                android:id="@+id/overlay_action"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/overlay_text_primary"
                android:textSize="@dimen/overlay_text_label"
                android:textIsSelectable="true"
                android:fontFamily="monospace"
                android:text="(等待数据)" />

        </LinearLayout>

    </ScrollView>

</LinearLayout>
